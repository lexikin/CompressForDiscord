<?xml version="1.0" encoding="utf-8"?>
<!-- Sparse package (AllowExternalContent): grants package identity so Windows 11 shows the
     modern context-menu entry. Stamped by build-sparse.ps1: __VERSION__, __CLSID__, and the
     EXTENSION_ITEMS block (from packaging/windows/extensions.json). Publisher must byte-match
     the signing certificate Subject. -->
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
         xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
         xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
         xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
         xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
         xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
         xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
         IgnorableNamespaces="uap uap10 com desktop4 desktop5 rescap">

  <Identity Name="CompressForDiscord.Shell"
            Publisher="CN=CompressForDiscordOSS"
            Version="__VERSION__"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Compress for Discord Shell Extension</DisplayName>
    <PublisherDisplayName>lexikin</PublisherDisplayName>
    <Logo>Assets\Store150x150.png</Logo>
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="unvirtualizedResources" /> <!-- required by AllowExternalContent -->
  </Capabilities>

  <Applications>
    <Application Id="App" Executable="CompressForDiscord.exe"
                 uap10:TrustLevel="mediumIL" uap10:RuntimeBehavior="win32App">
      <uap:VisualElements AppListEntry="none"
                          DisplayName="Compress for Discord"
                          Description="Compress images and videos to fit Discord's upload limit"
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\Store150x150.png"
                          Square44x44Logo="Assets\Store44x44.png" />
      <Extensions>
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <!-- Shell extensions load out-of-proc via the DllHost surrogate; the DLL path
                 rides on the Class element (same shape as vscode-explorer-command). -->
            <com:SurrogateServer DisplayName="Compress for Discord Shell Extension">
              <com:Class Id="__CLSID__" Path="CompressForDiscord.Shell.dll" ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
<!--EXTENSION_ITEMS-->
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
