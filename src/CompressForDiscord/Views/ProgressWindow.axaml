<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CompressForDiscord.ViewModels"
        x:Class="CompressForDiscord.Views.ProgressWindow"
        x:DataType="vm:ProgressWindowViewModel"
        Title="Compress for Discord"
        Width="440" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
  <StackPanel Margin="20,16" Spacing="10">
    <TextBlock Text="{Binding FileName}"
               FontWeight="SemiBold"
               TextTrimming="CharacterEllipsis" />
    <ProgressBar Minimum="0" Maximum="100" Height="8"
                 Value="{Binding Percent}"
                 IsIndeterminate="{Binding IsIndeterminate}" />
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="{Binding Phase}"
                 Opacity="0.7"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis"
                 Margin="0,0,12,0" />
      <Button Grid.Column="1"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsEnabled="{Binding CanCancel}" />
    </Grid>
  </StackPanel>
</Window>
